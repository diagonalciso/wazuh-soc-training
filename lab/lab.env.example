# Lab config for deploy-lab.sh. Copy to lab.env and edit.

# Real Wazuh manager the virtual endpoints enroll to (VM or bare metal).
MANAGER_IP=10.10.0.10

# Manager authd enrollment password, if set on the manager
# (/var/ossec/etc/authd.pass). Leave blank if password auth is disabled.
ENROLL_PASSWORD=

# Agent version to install in the containers. MUST be <= manager version.
WAZUH_VERSION=4.14.5

# Docker network for the virtual endpoints.
LAB_NETWORK=wazuh-lab
LAB_SUBNET=172.30.0.0/24

# Fleet definition file (name ip role group per line).
FLEET_FILE=fleet.txt

# Container name prefix (so teardown can find them).
NAME_PREFIX=wlab-
