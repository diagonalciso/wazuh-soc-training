# wazuh-soc-training — copy to /etc/wazuh-soc-training.env (chmod 600) and edit.
# This service runs ON the Wazuh manager (the analysisd queue socket is local).

# --- injection target (local UNIX socket, owned wazuh:wazuh -> run as root/wazuh) ---
QUEUE_SOCKET=/var/ossec/queue/sockets/queue

# --- indexer (read-only account, only used to verify events if you extend it) ---
INDEXER_URL=https://127.0.0.1:9200
INDEXER_USER=monitor
INDEXER_PASS=CHANGE_ME
INDEXER_CA=

# --- the real Wazuh dashboard the trainee triages in (link target) ---
WAZUH_DASHBOARD_URL=https://your-wazuh-host

# --- web app ---
TRAIN_PORT=8101
TRAIN_BIND=0.0.0.0
TRAIN_DB=/opt/wazuh-soc-training/training.db

# --- real agents on this manager: id:name,id:name  (name is shown to the trainee) ---
TRAIN_AGENTS=001:web01,003:db01,002:app01,004:ws01
