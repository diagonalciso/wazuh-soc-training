# wazuh-soc-training — copy to /etc/wazuh-soc-training.env (chmod 600) and edit.
# This service runs ON the Wazuh manager (the analysisd queue socket is local).

# --- injection target (local UNIX socket, owned wazuh:wazuh -> run as root/wazuh) ---
QUEUE_SOCKET=/var/ossec/queue/sockets/queue

# --- indexer (read-only account, only used to verify events if you extend it) ---
INDEXER_URL=https://127.0.0.1:9200
INDEXER_USER=monitor
INDEXER_PASS=CHANGE_ME
INDEXER_CA=

# --- REQUIRED: the real Wazuh dashboard the trainee triages in (link target) ---
WAZUH_DASHBOARD_URL=https://your-wazuh-host

# --- web app ---
TRAIN_PORT=8101
TRAIN_BIND=0.0.0.0          # narrow to an internal IP to limit exposure
TRAIN_DB=/opt/wazuh-soc-training/training.db

# --- REQUIRED: real agents on THIS manager: id:name:os (name shown to trainee) ---
# get with: sudo /var/ossec/bin/agent_control -l   (or lab/enroll-fleet.sh)
# os (optional, default linux) = linux | windows-server | windows-10 | windows-11
# Windows drills (RDP/Kerberos/Sysmon) only land on windows-* hosts; the sim also
# reports this so Windows agents show a real Windows OS in the dashboard.
TRAIN_AGENTS=001:web01:linux,002:db01:linux,003:dc01:windows-server,004:ws01:windows-10
